# Health OS Configuration
# Copy to .env and fill in your values

# WHOOP OAuth (optional — only if using WHOOP connector)
# HEALTH_OS_WHOOP_CLIENT_ID=your-client-id
# HEALTH_OS_WHOOP_CLIENT_SECRET=your-client-secret
# HEALTH_OS_WHOOP_REDIRECT_URI=https://your-callback-url/callback

# Telegram Bot (optional — only if using Telegram intake)
# HEALTH_OS_TELEGRAM_TOKEN=your-bot-token

# Weather enrichment (optional)
# HEALTH_OS_WEATHER_PROVIDER=open-meteo
