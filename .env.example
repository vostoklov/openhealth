# OpenHealth Configuration
# Copy to .env and fill in your values

# WHOOP OAuth (optional — only if using WHOOP connector)
# OPENHEALTH_WHOOP_CLIENT_ID=your-client-id
# OPENHEALTH_WHOOP_CLIENT_SECRET=your-client-secret
# OPENHEALTH_WHOOP_REDIRECT_URI=https://your-callback-url/callback
# Override requested OAuth scopes (space- or comma-separated). Defaults to the
# full set; narrow it if your app isn't granted read:profile / read:body_measurement,
# otherwise the authorize step fails with invalid_scope.
# OPENHEALTH_WHOOP_SCOPES=read:cycles read:recovery read:sleep read:workout offline

# Oura Ring OAuth (optional — only if using the live Oura connector)
# OPENHEALTH_OURA_CLIENT_ID=your-client-id
# OPENHEALTH_OURA_CLIENT_SECRET=your-client-secret
# OPENHEALTH_OURA_REDIRECT_URI=http://localhost:8765/callback
# Override requested OAuth scopes (space- or comma-separated). Defaults to
# "personal daily heartrate workout"; narrow it if your Oura app is granted fewer.
# OPENHEALTH_OURA_SCOPES=personal daily heartrate workout

# Telegram Bot (optional — only if using Telegram intake)
# OPENHEALTH_TELEGRAM_BOT_TOKEN=your-bot-token
# OPENHEALTH_TELEGRAM_ALLOWED_USERS=123456789,987654321

# Weather enrichment (optional)
# OPENHEALTH_WEATHER_PROVIDER=open-meteo
