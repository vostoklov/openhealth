# ── OpenHealth self-host config. Copy to deploy/.env and fill in. ──────────────
# Nothing here is committed; deploy/.env is gitignored.

# Public domain. Caddy auto-provisions a TLS certificate for it (point the
# domain's A/AAAA record at this server first).
OPENHEALTH_DOMAIN=health.example.com

# Basic-auth login guarding the entire app (web UI + API).
OPENHEALTH_USER=me
# Password HASH — never the plaintext. Generate it with:
#   docker run --rm caddy:2 caddy hash-password --plaintext 'your-strong-password'
OPENHEALTH_PASSWORD_HASH=

# ── LLM backend ───────────────────────────────────────────────────────────────
# OpenHealth talks to Hermes over its OpenAI-compatible proxy. Any bearer token
# works — the proxy attaches the real provider credentials from ~/.hermes.
# To use Hermes as the LLM, also set the agent to "hermes" in Settings → Agent.
OPENHEALTH_LLM_BASE_URL=http://hermes-proxy:8645
OPENHEALTH_LLM_API_KEY=openhealth

# ── Hermes (Telegram gateway + cron + proxy) ──────────────────────────────────
# Bot token from @BotFather. Leave blank to run without Telegram.
TELEGRAM_BOT_TOKEN=
# Map the container user to the host owner of the hermes data volume.
HERMES_UID=10000
HERMES_GID=10000
# Hermes image. Build it once from your Hermes checkout:
#   docker build -t hermes-agent /path/to/hermes-agent
HERMES_IMAGE=hermes-agent
