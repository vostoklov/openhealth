# Health OS — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit the .env file

# Database path (default: ./health-os.db)
# HEALTH_OS_DB_PATH=./health-os.db

# Enable database encryption (optional)
# HEALTH_OS_DB_ENCRYPT=false
# HEALTH_OS_DB_KEY=your-encryption-key

# Connector-specific settings go in each connector's .env.example
